#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int nums[100];
    for (int i = 0; i < n; i++) {
        cin >> nums[i];
    }
    for (int i = 0; i < n; i++) {
        int current_product = 1;
        for (int j = 0; j < n; j++) {
            if (i != j) {
                current_product = current_product * nums[j];
            }
        }
        cout << current_product << " ";
    }
    cout << endl;

    return 0;
}

