#include <iostream>
#include <cmath>

using namespace std;

int main() {
    long long n;
    cin >> n;

    if (n == 0) {
        cout << "No Factors" << endl;
        return 0;
    }

    if (n < 0) {
        n = abs(n);
    }

    for (long long i = 1; i <= n; i++) {
        if (n % i == 0) {
            cout << i << " ";
        }
    }
    cout << endl;

    return 0;
}
