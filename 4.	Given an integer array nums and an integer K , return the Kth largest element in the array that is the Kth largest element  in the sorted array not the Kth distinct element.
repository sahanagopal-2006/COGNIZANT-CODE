#include <iostream>
using namespace std;

int main() {
    int size;
    cin >> size;

    int nums[size];
    for (int i = 0; i < size; i++) {
        cin >> nums[i];
    }

    int k;
    cin >> k;

    for (int i = 0; i < size - 1; i++) {
        for (int j = 0; j < size - i - 1; j++) {
            if (nums[j] > nums[j + 1]) {
                int temp = nums[j];
                nums[j] = nums[j + 1];
                nums[j + 1] = temp;
            }
        }
    }

    cout << nums[size - k] << endl;

    return 0;
}
